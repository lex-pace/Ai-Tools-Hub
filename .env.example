# ============================================================
# AI Tools Hub — 环境变量配置
# ============================================================
# 使用方式:
#   cp .env.example .env
#   然后根据你的开发模式选择:
#     - 全 Docker 开发:    直接使用，不需要修改连接地址
#     - 本地 IDE 开发:     修改下方「本地开发连接配置」区域
# ============================================================

# ── 开发模式 ────────────────────────────────────────
# docker   = 全部在 Docker 中运行（前后端都在容器内）
# local    = 基础设施在 Docker，前后端在本地 IDE 运行
APP_MODE=docker

# ── Provider 选择（修改值即可切换国内外方案）────────
LLM_PROVIDER=siliconcloud
EMBEDDING_PROVIDER=siliconcloud
CRAWL_PROVIDER=gitee

# ── SiliconCloud（默认，国内直连）──────────────────
SILICONFLOW_API_KEY=your_siliconflow_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3

# ── Google Gemini（可选，需 VPN）───────────────────
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Groq（可选，需 VPN）───────────────────────────
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ── 百度千帆（可选，国内直连）──────────────────────
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_MODEL=ernie-speed-128k

# ── DeepSeek（可选，国内直连）──────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── 本地 Embedding（可选，完全离线）────────────────
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_DEVICE=cpu

# ── 数据采集 ───────────────────────────────────────
GITHUB_TOKEN=
GITEE_TOKEN=

# ── 应用配置 ───────────────────────────────────────
APP_ENV=development
APP_DEBUG=true

# ── JWT 认证 ──────────────────────────────────────
APP_SECRET=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── 限流配置 ──────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SEARCH_PER_MINUTE=30
RATE_LIMIT_CRAWL_PER_MINUTE=10
RATE_LIMIT_DEFAULT_PER_MINUTE=120

# ============================================================
# 连接配置（根据 APP_MODE 自动选择，通常不需要修改）
# ============================================================
#
# 当 APP_MODE=docker 时:
#   使用 Docker 内部地址（容器名通信）
#   PostgreSQL → postgres:5432
#   Redis      → redis:6379
#   ES         → http://elasticsearch:9200
#
# 当 APP_MODE=local 时:
#   使用局域网地址连接 VM 中的 Docker 服务
#   请将 DOCKER_HOST 改为你的 VM 的实际 IP
#   PostgreSQL → ${DOCKER_HOST}:5432
#   Redis      → ${DOCKER_HOST}:6379
#   ES         → http://${DOCKER_HOST}:9200
#
# ============================================================

# ── Docker 宿主机 IP（本地开发时填写 VM 的局域网 IP）──
DOCKER_HOST=192.168.1.100

# ── Docker 模式连接地址（容器名，仅 Docker 内部可用）──
DB_HOST_DOCKER=postgres
DB_PORT_DOCKER=5432
REDIS_HOST_DOCKER=redis
REDIS_PORT_DOCKER=6379
ES_HOST_DOCKER=elasticsearch
ES_PORT_DOCKER=9200

# ── 本地模式连接地址（VM 局域网 IP + 映射端口）──────
DB_HOST_LOCAL=${DOCKER_HOST}
DB_PORT_LOCAL=15432
REDIS_HOST_LOCAL=${DOCKER_HOST}
REDIS_PORT_LOCAL=16379
ES_HOST_LOCAL=${DOCKER_HOST}
ES_PORT_LOCAL=19200
